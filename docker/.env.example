# ──────────────────────────────────────────────────────────────────────────────
# Local Messenger — relay server environment variables
# Copy this file to docker/.env and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# Public hostname or IP of this server (used as TLS SNI and in invite links).
SERVER_NAME=relay.example.com

# Secret used to sign invite links.  Change this before deploying!
INVITE_SECRET=changeme-replace-in-production

# UDP port exposed to clients.  Must match the port in invite links.
RELAY_PORT=7443

# Optional rate-limiting tuning (uncomment to override defaults).
# RATE_WINDOW_SECONDS=60
# PEER_FRAME_LIMIT=120
# BLOB_REQUEST_LIMIT=32
# BLOB_CHUNK_BYTE_LIMIT=20971520
# HEALTH_CHECK_LIMIT=12
