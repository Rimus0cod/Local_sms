{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Local Messenger",
  "version": "0.1.0",
  "identifier": "com.rimus.localmessenger",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Local Messenger",
        "width": 1480,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true
  }
}
